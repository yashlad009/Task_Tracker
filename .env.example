MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Server port (optional)
PORT=8080

MONGODB_URI=mongodb://localhost:27017/apms

MAIL_USERNAME=replace-with-email
MAIL_PASSWORD=replace-with-app-password

