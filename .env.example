############################################
# Local development env (DO NOT COMMIT .env)
############################################

# --- Backend ---
# Used by Spring Boot via `application.properties`
GEMINI_API_KEY=
# Optional: override model endpoint if needed
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent

# PostgreSQL / Supabase
# Example:
# DATABASE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
HIBERNATE_DDL_AUTO=update

# Email (optional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Server port (optional)
PORT=8080
